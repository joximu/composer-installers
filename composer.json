{
  "name": "joximu/composer-installers",
  "type": "composer-plugin",
  "license": "LGPL-2.1-only",
  "description": "i-MSCP-joxi composer installers",
  "keywords": [
    "installers",
    "iMSCP-joxi",
    "tools",
    "plugins",
    "library",
    "roundcube"
  ],
  "homepage": "https://www.i-mscp.net/",
  "authors": [
    {
      "name": "Laurent Declercq",
      "email": "l.declercq@nuxwin.com",
      "homepage": "https://www.i-mscp.net"
    }
  ],
  "autoload": {
    "psr-4": {
      "iMSCP\\Composer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "iMSCPTest\\Composer\\": "test/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "class": "iMSCP\\Composer\\Plugin",
    "branch-alias": {
      "dev-master": "1.0-dev"
    }
  },
  "replace": {
    "roundcube/plugin-installer": "*"
  },
  "conflict": {
    "composer/installers": "*"
  },
  "require": {
    "php": "^7.1",
    "composer-plugin-api": "^1.1"
  },
  "require-dev": {
    "composer/composer": "^1.8",
    "imscp/imscp-coding-standard": "^1.0",
    "phpunit/phpunit": "^7.5.6",
    "roave/security-advisories": "dev-master"
  },
  "scripts": {
    "check": [
      "@cs-check",
      "@test"
    ],
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "test": "phpunit --colors=always",
    "test-coverage": "phpunit --colors=always --coverage-clover clover.xml"
  }
}
